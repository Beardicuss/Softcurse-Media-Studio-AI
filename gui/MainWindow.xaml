<Window x:Class="GeminiWatermarkRemover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:ThemeManager.RequestedTheme="Dark"
        Style="{StaticResource CyberWindowStyle}"
        Title="Softcurse Media Studio AI" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Grid Width="1000" Height="1000" Background="{StaticResource CyberGridBrush}" Opacity="0.5" />
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.Background>
        
        <!-- Glassmorphism underlying layer -->
        <Border Background="#C0020202" />

        <ui:NavigationView x:Name="NavView" PaneDisplayMode="Left" SelectionChanged="NavView_SelectionChanged" IsSettingsVisible="True" Background="Transparent" Foreground="#00FFFF">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="IMAGE EDITOR" Tag="ImagePage" Icon="Edit" Foreground="{StaticResource CyberAccentBrush}" />
                <ui:NavigationViewItem Content="BATCH PROCESSOR" Tag="BatchPage" Icon="Copy" Foreground="{StaticResource CyberAccentBrush}" />
                <ui:NavigationViewItem Content="VIDEO LAB" Tag="VideoPage" Icon="Video" Foreground="{StaticResource CyberAccentBrush}" />
                <ui:NavigationViewItem Content="AI GENERATION HUB" Tag="GenFillPage" Icon="Highlight" Foreground="{StaticResource CyberAccentBrush}" />
            </ui:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" Background="Transparent" />
        </ui:NavigationView>
    </Grid>
</Window>
