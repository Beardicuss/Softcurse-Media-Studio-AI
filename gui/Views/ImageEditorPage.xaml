<UserControl x:Class="SoftcurseMediaLabAI.Views.ImageEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar row -->
            <RowDefinition Height="*"/>     <!-- Canvas row -->
            <RowDefinition Height="Auto"/>  <!-- Status / tools row -->
        </Grid.RowDefinitions>

        <!-- ── ROW 0: TOOLBAR ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#07101A"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: MODE selector -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MODE" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource TextDimBrush}" FontSize="10"
                               FontFamily="Segoe UI" FontWeight="Bold"/>
                    <ComboBox x:Name="ToolComboBox" Width="145" Height="30" SelectedIndex="0"
                              SelectionChanged="ToolComboBox_SelectionChanged"
                              Style="{StaticResource HudComboBox}">
                        <ComboBoxItem Content="EDITOR" />
                        <ComboBoxItem Content="CYBER BRUSH" />
                        <ComboBoxItem Content="ERASER" />
                        <ComboBoxItem Content="POLY LASSO" />
                        <ComboBoxItem Content="MAGIC WAND" />
                        <ComboBoxItem Content="MOVE" />
                        <ComboBoxItem Content="COLOR PICKER" />
                        <ComboBoxItem Content="GRADIENT" />
                        <ComboBoxItem Content="TEXT" />
                        <ComboBoxItem Content="LAYER MASK" />
                    </ComboBox>
                </StackPanel>

                <!-- Center: Core action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Button x:Name="BackgroundButton" Content="BG REMOVE" Height="30" Margin="0,0,6,0"
                            Style="{StaticResource BtnOutline}" Padding="10,0"
                            Click="RemoveBackground_Click" IsEnabled="False" ToolTip="Remove Background"/>

                    <Button x:Name="RetouchButton" Content="RETOUCH" Height="30" Margin="0,0,6,0"
                            Style="{StaticResource BtnPrimary}" Padding="10,0"
                            Click="RemoveWatermark_Click" IsEnabled="False" ToolTip="Apply Mask (Retouch)"/>

                    <Button x:Name="ExpandButton" Content="EXPAND" Height="30" Margin="0,0,6,0"
                            Style="{StaticResource BtnOutline}" Padding="10,0"
                            Click="Expand_Click" IsEnabled="False" ToolTip="Expand Canvas"/>

                    <Button x:Name="UpscaleButton" Content="UPSCALE" Height="30" Margin="0,0,6,0"
                            Style="{StaticResource BtnOutline}" Padding="10,0"
                            Click="Upscale_Click" IsEnabled="False" ToolTip="AI Upscale"/>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="0,0,6,0"/>

                    <Button x:Name="FilterBlurButton" Content="BLUR" Height="30" Margin="0,0,4,0"
                            Style="{StaticResource BtnOutline}" Padding="10,0" FontSize="11"
                            Click="FilterBlur_Click" IsEnabled="False" ToolTip="Gaussian Blur"/>
                    <Button x:Name="FilterSharpenButton" Content="SHARP" Height="30" Margin="0,0,4,0"
                            Style="{StaticResource BtnOutline}" Padding="10,0" FontSize="11"
                            Click="FilterSharpen_Click" IsEnabled="False" ToolTip="Sharpen"/>
                    <Button x:Name="FilterNoiseButton" Content="NOISE" Height="30" Margin="0,0,6,0"
                            Style="{StaticResource BtnOutline}" Padding="10,0" FontSize="11"
                            Click="FilterNoise_Click" IsEnabled="False" ToolTip="Add Noise"/>

                </StackPanel>

                <!-- Right: Undo/Redo + Save / Copy / Compare / Reset -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <Button x:Name="UndoButton" Content="↶" Height="30" Width="30" Margin="0,0,4,0"
                            Style="{StaticResource BtnOutline}" Padding="0" FontSize="16"
                            Click="Undo_Click" ToolTip="Undo (Ctrl+Z)" IsEnabled="False"/>
                    <Button x:Name="RedoButton" Content="↷" Height="30" Width="30" Margin="0,0,8,0"
                            Style="{StaticResource BtnOutline}" Padding="0" FontSize="16"
                            Click="Redo_Click" ToolTip="Redo (Ctrl+Shift+Z)" IsEnabled="False"/>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="0,0,8,0"/>

                    <Button x:Name="CopyButton" Content="COPY" Height="30" Margin="0,0,6,0"
                            Style="{StaticResource BtnOutline}" Padding="12,0"
                            Click="Copy_Click" IsEnabled="False" ToolTip="Ctrl+C"/>

                    <Button x:Name="SaveButton" Content="SAVE" Height="30" Margin="0,0,6,0"
                            Style="{StaticResource BtnOutline}" Padding="12,0"
                            Click="Save_Click" IsEnabled="False" ToolTip="Ctrl+S"/>

                    <ToggleButton x:Name="CompareToggleButton" Content="COMPARE" Height="30" Margin="0,0,6,0"
                                  Style="{StaticResource ToggleOutline}" Padding="12,0"
                                  Checked="Compare_Checked" Unchecked="Compare_Unchecked" IsEnabled="False"/>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0,8,0"/>

                    <Button x:Name="ResetButton" Content="RESET" Height="30"
                            Style="{StaticResource BtnDanger}" Padding="12,0"
                            Click="Reset_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── ROW 1: IMAGE CANVAS ─────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="12,10,12,10">

            <!-- Brush size panel (hidden unless brush/eraser tool active) -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Brush controls bar -->
            <StackPanel x:Name="BrushSizePanel" Grid.Row="0" Orientation="Horizontal"
                        Margin="0,0,0,6" Visibility="Collapsed">
                <TextBlock Text="BRUSH SIZE" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" FontWeight="Bold"/>
                <Slider x:Name="BrushSizeSlider" Minimum="5" Maximum="100" Value="20" Width="130"
                        VerticalAlignment="Center" ValueChanged="BrushSize_ValueChanged"
                        Foreground="{StaticResource CyberAccentBrush}"/>
                <TextBlock Text="|" Margin="12,0" Foreground="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                <Button x:Name="ClearMaskButton" Content="CLEAR MASK" Height="26"
                        Style="{StaticResource BtnDanger}" Padding="10,0"
                        Click="ClearMask_Click" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Gradient settings panel -->
            <StackPanel x:Name="GradientSettingsPanel" Grid.Row="0" Orientation="Horizontal"
                        Margin="0,0,0,6" Visibility="Collapsed">
                <TextBlock Text="GRADIENT" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" FontWeight="Bold"/>
                <ComboBox x:Name="GradientTypeCombo" Width="100" Height="26" SelectedIndex="0"
                          Style="{StaticResource HudComboBox}">
                    <ComboBoxItem Content="LINEAR"/>
                    <ComboBoxItem Content="RADIAL"/>
                </ComboBox>
                <TextBlock Text="|" Margin="8,0" Foreground="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Uses FG → BG colors" VerticalAlignment="Center"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,0,8,0"/>
                <Button Content="APPLY GRADIENT" Height="26"
                        Style="{StaticResource BtnPrimary}" Padding="10,0"
                        Click="ApplyGradient_Click"/>
            </StackPanel>

            <!-- Text settings panel -->
            <StackPanel x:Name="TextSettingsPanel" Grid.Row="0" Orientation="Horizontal"
                        Margin="0,0,0,6" Visibility="Collapsed">
                <TextBlock Text="FONT" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" FontWeight="Bold"/>
                <ComboBox x:Name="FontFamilyCombo" Width="120" Height="26" SelectedIndex="0"
                          Style="{StaticResource HudComboBox}">
                    <ComboBoxItem Content="Segoe UI"/>
                    <ComboBoxItem Content="Arial"/>
                    <ComboBoxItem Content="Consolas"/>
                    <ComboBoxItem Content="Times New Roman"/>
                    <ComboBoxItem Content="Impact"/>
                    <ComboBoxItem Content="Georgia"/>
                </ComboBox>
                <TextBlock Text="SIZE" VerticalAlignment="Center" Margin="8,0,6,0"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" FontWeight="Bold"/>
                <Slider x:Name="TextSizeSlider" Minimum="8" Maximum="120" Value="24" Width="100"
                        VerticalAlignment="Center" Foreground="{StaticResource CyberAccentBrush}"/>
                <TextBlock x:Name="TextSizeLabel" Text="24" VerticalAlignment="Center" Margin="4,0,8,0"
                           Foreground="{StaticResource TextBrush}" FontSize="10" FontFamily="Consolas"/>
                <TextBlock Text="|" Margin="0,0,8,0" Foreground="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Uses FG color" VerticalAlignment="Center"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,0,8,0"/>
                <Button Content="APPLY TEXT" Height="26"
                        Style="{StaticResource BtnPrimary}" Padding="10,0"
                        Click="ApplyText_Click"/>
            </StackPanel>

            <!-- Layer Mask settings panel -->
            <StackPanel x:Name="LayerMaskPanel" Grid.Row="0" Orientation="Horizontal"
                        Margin="0,0,0,6" Visibility="Collapsed">
                <TextBlock Text="LAYER MASK" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" FontWeight="Bold"/>
                <TextBlock Text="BRUSH" VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI"/>
                <Slider x:Name="MaskBrushSizeSlider" Minimum="5" Maximum="100" Value="30" Width="100"
                        VerticalAlignment="Center" Foreground="{StaticResource CyberAccentBrush}"/>
                <TextBlock Text="|" Margin="8,0" Foreground="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                <ToggleButton x:Name="MaskColorToggle" Content="WHITE (REVEAL)" Height="26" Margin="0,0,6,0"
                              Style="{StaticResource ToggleOutline}" Padding="8,0" FontSize="10"
                              Checked="MaskColorToggle_Checked" Unchecked="MaskColorToggle_Unchecked"
                              ToolTip="Toggle: White reveals, Black hides"/>
                <TextBlock Text="|" Margin="0,0,8,0" Foreground="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                <ToggleButton x:Name="ShowMaskToggle" Content="SHOW MASK" Height="26" Margin="0,0,6,0"
                              Style="{StaticResource ToggleOutline}" Padding="8,0" FontSize="10"
                              Checked="ShowMask_Checked" Unchecked="ShowMask_Unchecked"
                              ToolTip="Toggle mask overlay visibility"/>
                <Button Content="FLATTEN" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource BtnPrimary}" Padding="10,0"
                        Click="FlattenMask_Click" ToolTip="Apply mask permanently to image"/>
                <Button Content="CLEAR" Height="26"
                        Style="{StaticResource BtnDanger}" Padding="10,0"
                        Click="ClearLayerMask_Click" ToolTip="Reset mask to fully visible"/>
            </StackPanel>

            <!-- HUD canvas frame -->
            <Border Grid.Row="1" x:Name="CanvasFrame"
                    BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                    Background="#050C13" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#00E5FF" BlurRadius="24" ShadowDepth="0" Opacity="0.25"/>
                </Border.Effect>

                <Grid>
                    <!-- Inner scan-line overlay (very subtle) -->
                    <Rectangle IsHitTestVisible="False" Opacity="0.04">
                        <Rectangle.Fill>
                            <DrawingBrush Viewport="0,0,1,3" ViewportUnits="Absolute" TileMode="Tile">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,1,1"/>
                                        </GeometryDrawing.Geometry>
                                        <GeometryDrawing.Brush>
                                            <SolidColorBrush Color="#00AAFF"/>
                                        </GeometryDrawing.Brush>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Main scrollable image area -->
                    <ScrollViewer x:Name="ImageScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PanningMode="Both"
                                  AllowDrop="True" Drop="DropZone_Drop">
                        <Grid x:Name="ImageContainer"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              SizeChanged="ImageContainer_SizeChanged">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Grid.LayoutTransform>

                            <Image x:Name="OriginalImageDisplay" Stretch="None"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="Collapsed"/>
                            <Image x:Name="ImageDisplay" Stretch="None"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Clip>
                                    <RectangleGeometry x:Name="ImageClipGeometry"/>
                                </Image.Clip>
                            </Image>

                            <!-- Masking layers -->
                            <Grid x:Name="MaskingContainer" Background="Transparent">
                                <InkCanvas x:Name="ManualInkCanvas" Background="Transparent" Visibility="Collapsed">
                                    <InkCanvas.DefaultDrawingAttributes>
                                        <DrawingAttributes Color="#CC00AAFF" Width="20" Height="20" FitToCurve="True"/>
                                    </InkCanvas.DefaultDrawingAttributes>
                                </InkCanvas>
                                <Canvas x:Name="PolygonCanvas" Background="Transparent" Visibility="Collapsed"
                                        MouseLeftButtonDown="PolygonCanvas_MouseLeftButtonDown"
                                        MouseMove="PolygonCanvas_MouseMove"
                                        MouseRightButtonDown="PolygonCanvas_MouseRightButtonDown"/>
                                <Canvas x:Name="SamCanvas" Background="Transparent" Visibility="Collapsed"
                                        MouseLeftButtonDown="SamCanvas_MouseLeftButtonDown"/>
                            </Grid>

                            <!-- Compare slider -->
                            <Slider x:Name="CompareSlider" Minimum="0" Maximum="1" Value="0.5"
                                    Visibility="Collapsed" VerticalAlignment="Center" Height="50"
                                    HorizontalAlignment="Stretch" Opacity="0.7"
                                    ValueChanged="CompareSlider_ValueChanged"
                                    Foreground="{StaticResource CyberAccentBrush}"/>
                        </Grid>
                    </ScrollViewer>

                    <!-- Drop zone overlay -->
                    <StackPanel x:Name="DropZone" Background="Transparent"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsHitTestVisible="False">
                        <TextBlock Text="⬡" FontSize="40" HorizontalAlignment="Center"
                                   Foreground="{StaticResource BorderBrightBrush}"/>
                        <TextBlock Text="DROP IMAGE HERE" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"
                                   Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI"/>
                        <TextBlock Text="or use LOAD IMAGE below" FontSize="11"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource BorderBrightBrush}" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- HUD corner brackets overlay on canvas -->
                    <Canvas IsHitTestVisible="False">
                        <!-- TL -->
                        <Rectangle Canvas.Left="0"  Canvas.Top="0"  Width="20" Height="1.5" Fill="{StaticResource CyberAccentBrush}" Opacity="0.6"/>
                        <Rectangle Canvas.Left="0"  Canvas.Top="0"  Width="1.5" Height="20" Fill="{StaticResource CyberAccentBrush}" Opacity="0.6"/>
                        <!-- TR -->
                        <Rectangle Canvas.Right="0" Canvas.Top="0"  Width="20" Height="1.5" Fill="{StaticResource CyberAccentBrush}" Opacity="0.6" HorizontalAlignment="Right"/>
                        <Rectangle Canvas.Right="0" Canvas.Top="0"  Width="1.5" Height="20" Fill="{StaticResource CyberAccentBrush}" Opacity="0.6" HorizontalAlignment="Right"/>
                        <!-- BL -->
                        <Rectangle Canvas.Left="0"  Canvas.Bottom="0" Width="20" Height="1.5" Fill="{StaticResource CyberAccentBrush}" Opacity="0.6" VerticalAlignment="Bottom"/>
                        <Rectangle Canvas.Left="0"  Canvas.Bottom="0" Width="1.5" Height="20" Fill="{StaticResource CyberAccentBrush}" Opacity="0.6" VerticalAlignment="Bottom"/>
                        <!-- BR -->
                        <Rectangle Canvas.Right="0" Canvas.Bottom="0" Width="20" Height="1.5" Fill="{StaticResource CyberAccentBrush}" Opacity="0.6" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Rectangle Canvas.Right="0" Canvas.Bottom="0" Width="1.5" Height="20" Fill="{StaticResource CyberAccentBrush}" Opacity="0.6" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Canvas>

                    <!-- Top-right HUD mini readout -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                                Orientation="Horizontal" Margin="0,6,8,0" IsHitTestVisible="False">
                        <TextBlock x:Name="ZoomReadout" Text="UTTo" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Consolas" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ResReadout" Text="USp" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ── ROW 2: BOTTOM STATUS + TOOL STRIP ───────────────────────── -->
        <Border Grid.Row="2" Background="#07101A"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>    <!-- Status / sliders -->
                    <ColumnDefinition Width="Auto"/> <!-- Tool icons -->
                    <ColumnDefinition Width="Auto"/> <!-- Load + hint -->
                </Grid.ColumnDefinitions>

                <!-- Left: Status + Zoom controls -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Status line -->
                    <TextBlock x:Name="StatusText" Grid.Row="0"
                               Text="SYSTEM READY"
                               Foreground="{StaticResource CyberAccentBrush}"
                               FontFamily="Consolas" FontSize="11"
                               Margin="0,0,0,6"/>

                    <!-- Zoom controls -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBlock Text="ZOOM" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <Button Content="FIT" Height="24" Width="36" Margin="0,0,4,0"
                                Style="{StaticResource BtnOutline}" Padding="0" FontSize="9"
                                Click="ZoomFit_Click" ToolTip="Fit to Screen (Ctrl+0)"/>
                        <Button Content="100%" Height="24" Width="42" Margin="0,0,4,0"
                                Style="{StaticResource BtnOutline}" Padding="0" FontSize="9"
                                Click="Zoom100_Click" ToolTip="Actual Size (Ctrl+1)"/>
                        <Button Content="−" Height="24" Width="24" Margin="0,0,2,0"
                                Style="{StaticResource BtnOutline}" Padding="0" FontSize="14"
                                Click="ZoomOut_Click" ToolTip="Zoom Out (-)"/>
                        <Button Content="+" Height="24" Width="24" Margin="0,0,8,0"
                                Style="{StaticResource BtnOutline}" Padding="0" FontSize="14"
                                Click="ZoomIn_Click" ToolTip="Zoom In (+)"/>
                        <TextBlock x:Name="ZoomLevelText" Text="100%" FontSize="10"
                                   Foreground="{StaticResource TextBrush}" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Center: Tool icon strip -->
                <Border Grid.Column="1" Margin="16,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0"
                        Padding="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- EDITOR tool -->
                        <StackPanel Margin="0,0,12,0" Cursor="Hand"
                                    MouseLeftButtonDown="ToolIcon_Editor_Click">
                            <Border x:Name="EditorToolBorder" Background="#1500E5FF" BorderBrush="{StaticResource CyberAccentBrush}"
                                    BorderThickness="1" Padding="6">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00E5FF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="30" Height="30">
                                        <!-- Cursor/pointer icon -->
                                        <Polygon Points="6,4 6,22 12,17 18,24 21,22 15,15 22,15"
                                                 Stroke="#00E5FF" StrokeThickness="1.2" Fill="#0A1830"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="EDITOR" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource CyberAccentBrush}" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- CYBER BRUSH -->
                        <StackPanel Margin="0,0,12,0" Cursor="Hand"
                                    MouseLeftButtonDown="ToolIcon_CyberBrush_Click">
                            <Border x:Name="BrushToolBorder" Background="#07101A" BorderBrush="{StaticResource BorderBrightBrush}"
                                    BorderThickness="1" Padding="6">
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="30" Height="30">
                                        <!-- Brush from softcurse-icons: line + circle + sparkles -->
                                        <Line X1="5" Y1="5" X2="20" Y2="20" Stroke="#00E5FF" StrokeThickness="2"/>
                                        <Ellipse Canvas.Left="15" Canvas.Top="15" Width="10" Height="10"
                                                 Stroke="#00E5FF" StrokeThickness="1.2" Fill="#0A1830"/>
                                        <Line X1="22" Y1="22" X2="27" Y2="27" Stroke="#C8973A" StrokeThickness="1.5"/>
                                        <Ellipse Canvas.Left="11" Canvas.Top="9" Width="3" Height="3" Fill="#00E5FF"/>
                                        <Ellipse Canvas.Left="7" Canvas.Top="14" Width="2" Height="2" Fill="#00E5FF" Opacity="0.6"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="CYBER BRUSH" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- ERASER -->
                        <StackPanel Margin="0,0,12,0" Cursor="Hand"
                                    MouseLeftButtonDown="ToolIcon_Eraser_Click">
                            <Border x:Name="EraserToolBorder" Background="#07101A" BorderBrush="{StaticResource BorderBrightBrush}"
                                    BorderThickness="1" Padding="6">
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="30" Height="30">
                                        <!-- Eraser from softcurse-icons -->
                                        <Rectangle Canvas.Left="5" Canvas.Top="10" Width="20" Height="12"
                                                   Stroke="#00E5FF" StrokeThickness="1.2" Fill="#0A1830" RadiusX="2" RadiusY="2"/>
                                        <Line X1="14" Y1="10" X2="14" Y2="22" Stroke="#00E5FF" StrokeThickness="1" Opacity="0.4"/>
                                        <Line X1="5" Y1="22" X2="14" Y2="22" Stroke="#C8973A" StrokeThickness="2"/>
                                        <Line X1="18" Y1="7" X2="25" Y2="14" Stroke="#00E5FF" StrokeThickness="1.2" Opacity="0.5"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="ERASER" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- POLY LASSO -->
                        <StackPanel Margin="0,0,12,0" Cursor="Hand"
                                    MouseLeftButtonDown="ToolIcon_PolyLasso_Click">
                            <Border x:Name="LassoToolBorder" Background="#07101A" BorderBrush="{StaticResource BorderBrightBrush}"
                                    BorderThickness="1" Padding="6">
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="30" Height="30">
                                        <!-- Poly Lasso from softcurse-icons -->
                                        <Polyline Points="5,20 10,8 18,12 24,6 26,20 15,25"
                                                  Stroke="#00E5FF" StrokeThickness="1.2" StrokeDashArray="3 2">
                                            <Polyline.RenderTransform>
                                                <TranslateTransform X="0" Y="0"/>
                                            </Polyline.RenderTransform>
                                        </Polyline>
                                        <Ellipse Canvas.Left="4" Canvas.Top="19" Width="4" Height="4" Fill="#C8973A"/>
                                        <Ellipse Canvas.Left="9" Canvas.Top="7" Width="3" Height="3" Fill="#00E5FF"/>
                                        <Ellipse Canvas.Left="17" Canvas.Top="11" Width="3" Height="3" Fill="#00E5FF"/>
                                        <Ellipse Canvas.Left="23" Canvas.Top="5" Width="3" Height="3" Fill="#00E5FF"/>
                                        <Ellipse Canvas.Left="25" Canvas.Top="19" Width="3" Height="3" Fill="#00E5FF"/>
                                        <Ellipse Canvas.Left="14" Canvas.Top="24" Width="3" Height="3" Fill="#00E5FF"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="POLY LASSO" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- MAGIC WAND -->
                        <StackPanel Margin="0,0,12,0" Cursor="Hand"
                                    MouseLeftButtonDown="ToolIcon_MagicWand_Click">
                            <Border x:Name="WandToolBorder" Background="#07101A" BorderBrush="{StaticResource BorderBrightBrush}"
                                    BorderThickness="1" Padding="6">
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="30" Height="30">
                                        <!-- Magic Wand from softcurse-icons -->
                                        <Line X1="6" Y1="24" X2="20" Y2="10" Stroke="#00E5FF" StrokeThickness="1.8"/>
                                        <!-- Sparkle cross -->
                                        <Line X1="22" Y1="6" X2="22" Y2="10" Stroke="#C8973A" StrokeThickness="1.5"/>
                                        <Line X1="20" Y1="8" X2="24" Y2="8" Stroke="#C8973A" StrokeThickness="1.5"/>
                                        <!-- Extra sparkles -->
                                        <Line X1="25" Y1="12" X2="27" Y2="14" Stroke="#00E5FF" StrokeThickness="1" Opacity="0.6"/>
                                        <Line X1="17" Y1="5" X2="19" Y2="7" Stroke="#00E5FF" StrokeThickness="1" Opacity="0.6"/>
                                        <Ellipse Canvas.Left="21" Canvas.Top="7" Width="3" Height="3" Fill="#C8973A"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="MAGIC WAND" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- MOVE -->
                        <StackPanel Margin="0,0,12,0" Cursor="Hand"
                                    MouseLeftButtonDown="ToolIcon_Move_Click">
                            <Border x:Name="MoveToolBorder" Background="#07101A" BorderBrush="{StaticResource BorderBrightBrush}"
                                    BorderThickness="1" Padding="6">
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="30" Height="30">
                                        <!-- Move arrows icon -->
                                        <Line X1="15" Y1="4" X2="15" Y2="26" Stroke="#00E5FF" StrokeThickness="1.5"/>
                                        <Line X1="4" Y1="15" X2="26" Y2="15" Stroke="#00E5FF" StrokeThickness="1.5"/>
                                        <Polygon Points="15,3 12,8 18,8" Fill="#00E5FF"/>
                                        <Polygon Points="15,27 12,22 18,22" Fill="#00E5FF"/>
                                        <Polygon Points="3,15 8,12 8,18" Fill="#00E5FF"/>
                                        <Polygon Points="27,15 22,12 22,18" Fill="#00E5FF"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="MOVE" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- COLOR PICKER -->
                        <StackPanel Margin="0,0,0,0" Cursor="Hand"
                                    MouseLeftButtonDown="ToolIcon_ColorPicker_Click">
                            <Border x:Name="ColorPickerToolBorder" Background="#07101A" BorderBrush="{StaticResource BorderBrightBrush}"
                                    BorderThickness="1" Padding="6">
                                <Viewbox Width="28" Height="28">
                                    <Canvas Width="30" Height="30">
                                        <!-- Eyedropper icon -->
                                        <Line X1="8" Y1="22" X2="20" Y2="10" Stroke="#00E5FF" StrokeThickness="2"/>
                                        <Ellipse Canvas.Left="17" Canvas.Top="5" Width="10" Height="10"
                                                 Stroke="#00E5FF" StrokeThickness="1.2" Fill="#0A1830"/>
                                        <Ellipse Canvas.Left="5" Canvas.Top="20" Width="5" Height="5" Fill="#C8973A"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="COLOR" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Rectangle Width="1" Height="36" Fill="{StaticResource BorderBrush}" Margin="12,0,12,0" VerticalAlignment="Center"/>

                        <!-- Color swatches (FG/BG) -->
                        <StackPanel VerticalAlignment="Center">
                            <Grid Width="32" Height="32">
                                <Border x:Name="BgColorSwatch" Width="20" Height="20"
                                        Background="White" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Cursor="Hand" MouseLeftButtonDown="BgColorSwatch_Click"
                                        ToolTip="Background Color"/>
                                <Border x:Name="FgColorSwatch" Width="20" Height="20"
                                        Background="Black" BorderBrush="{StaticResource CyberAccentBrush}"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Cursor="Hand" MouseLeftButtonDown="FgColorSwatch_Click"
                                        ToolTip="Foreground Color"/>
                            </Grid>
                            <TextBlock Text="FG/BG" FontSize="7" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- Right: Load image + zoom hint -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="LOAD IMAGE" Height="30" Margin="0,0,0,6"
                            Style="{StaticResource BtnOutline}" Padding="14,0"
                            Click="SelectImage_Click"/>
                    <TextBlock Text="B=Brush  E=Eraser  V=Move  M=Wand  Ctrl+Z=Undo"
                               FontSize="9" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="Consolas" HorizontalAlignment="Center"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>
