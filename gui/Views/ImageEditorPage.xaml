<UserControl x:Class="GeminiWatermarkRemover.Views.ImageEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid>

        
        <Grid Margin="20">
            <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="Auto"/> <!-- Controls -->
            <RowDefinition Height="*"/>    <!-- Image -->
            <RowDefinition Height="Auto"/> <!-- Status -->
        </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="SOFTCURSE MEDIA STUDIO AI" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="{StaticResource CyberAccentBrush}">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="15" ShadowDepth="0" />
                </TextBlock.Effect>
            </TextBlock>

        <!-- Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            
            <TextBlock Text="MODE:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{StaticResource CyberAccentBrush}" />
            <ComboBox x:Name="ToolComboBox" Margin="0,0,10,0" Width="150" SelectedIndex="0" SelectionChanged="ToolComboBox_SelectionChanged" BorderBrush="{StaticResource CyberAccentBrush}" BorderThickness="1">
                <ComboBoxItem Content="AUTO MODE" />
                <ComboBoxItem Content="CYBER BRUSH" />
                <ComboBoxItem Content="ERASER" />
                <ComboBoxItem Content="POLY LASSO" />
                <ComboBoxItem Content="MAGIC WAND" />
            </ComboBox>

            <StackPanel x:Name="BrushSizePanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed">
                <TextBlock Text="SIZE:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{StaticResource CyberAccentBrush}"/>
                <Slider x:Name="BrushSizeSlider" Minimum="5" Maximum="100" Value="20" Width="100" VerticalAlignment="Center" ValueChanged="BrushSize_ValueChanged"/>
            </StackPanel>
            
            <Button Content="CLEAR MASK" x:Name="ClearMaskButton" Visibility="Collapsed" Width="90" Height="30" Margin="0,0,10,0" Click="ClearMask_Click" BorderBrush="{StaticResource CyberMagentaBrush}" Foreground="{StaticResource CyberMagentaBrush}" BorderThickness="1" Background="Transparent" />
            <Button x:Name="ResetButton" Content="RESET" Width="50" Height="30" Margin="0,0,10,0" Click="Reset_Click" Background="{StaticResource CyberMagentaBrush}" Foreground="#020202" FontWeight="Bold" BorderThickness="0"/>
            
            <!-- The 4 Core Pixa Tools -->
            <Button x:Name="BackgroundButton" Content="BACKGROUND" Width="120" Height="30" Margin="0,0,10,0" Click="RemoveBackground_Click" BorderBrush="{StaticResource CyberMagentaBrush}" Foreground="{StaticResource CyberMagentaBrush}" BorderThickness="1" Background="Transparent" IsEnabled="False"/>
            <Button x:Name="RetouchButton" Content="APPLY MASK (RETOUCH)" Width="190" Height="30" Margin="0,0,10,0" Click="RemoveWatermark_Click" ui:ControlHelper.CornerRadius="0" Background="{StaticResource CyberAccentBrush}" Foreground="#020202" FontWeight="Bold" IsEnabled="False">
                <Button.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="10" ShadowDepth="0" />
                </Button.Effect>
            </Button>
            <Button x:Name="ExpandButton" Content="EXPAND" Width="100" Height="30" Margin="0,0,10,0" Click="Expand_Click" BorderBrush="{StaticResource CyberSecondaryBrush}" Foreground="{StaticResource CyberSecondaryBrush}" BorderThickness="1" Background="Transparent" IsEnabled="False"/>
            <Button x:Name="UpscaleButton" Content="UPSCALE" Width="100" Height="30" Margin="0,0,10,0" Click="Upscale_Click" IsEnabled="False" BorderBrush="{StaticResource CyberSecondaryBrush}" Foreground="{StaticResource CyberSecondaryBrush}" BorderThickness="1" Background="Transparent"/>

            <Button x:Name="CopyButton" Content="COPY" ToolTip="Ctrl+C" Width="50" Height="30" Margin="0,0,10,0" Click="Copy_Click" BorderBrush="{StaticResource CyberSecondaryBrush}" Foreground="{StaticResource CyberSecondaryBrush}" BorderThickness="1" Background="Transparent" IsEnabled="False"/>
            <Button x:Name="SaveButton" Content="SAVE" Width="60" Height="30" Click="Save_Click" Background="{StaticResource CyberSecondaryBrush}" Foreground="#020202" FontWeight="Bold" BorderThickness="0" IsEnabled="False">
                <Button.Effect>
                    <DropShadowEffect Color="#0088FF" BlurRadius="10" ShadowDepth="0" />
                </Button.Effect>
            </Button>
            <ToggleButton x:Name="CompareToggleButton" Content="COMPARE" Width="80" Height="30" Margin="10,0,0,0" Checked="Compare_Checked" Unchecked="Compare_Unchecked" IsEnabled="False" BorderBrush="{StaticResource CyberAccentBrush}" Foreground="{StaticResource CyberAccentBrush}" BorderThickness="1" Background="Transparent"/>
        </StackPanel>

        <!-- Image Display with Zoom -->
        <Border Grid.Row="2" BorderBrush="{StaticResource CyberAccentBrush}" BorderThickness="1" Margin="0,0,0,10" Background="#1100FFFF" CornerRadius="0" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#00FFFF" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <ScrollViewer x:Name="ImageScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PanningMode="Both">
                    <Grid x:Name="ImageContainer" HorizontalAlignment="Center" VerticalAlignment="Center" SizeChanged="ImageContainer_SizeChanged">
                        <Grid.LayoutTransform>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                        </Grid.LayoutTransform>
                        <Image x:Name="OriginalImageDisplay" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality" Visibility="Collapsed"/>
                        <Image x:Name="ImageDisplay" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Clip>
                                <RectangleGeometry x:Name="ImageClipGeometry" />
                            </Image.Clip>
                        </Image>
                        <Grid x:Name="MaskingContainer" Background="Transparent" Visibility="Visible">
                            <InkCanvas x:Name="ManualInkCanvas" Background="Transparent" Visibility="Collapsed">
                                <InkCanvas.DefaultDrawingAttributes>
                                    <DrawingAttributes Color="#80FF0000" Width="20" Height="20" FitToCurve="True"/>
                                </InkCanvas.DefaultDrawingAttributes>
                            </InkCanvas>
                            <Canvas x:Name="PolygonCanvas" Background="Transparent" Visibility="Collapsed" 
                                    MouseLeftButtonDown="PolygonCanvas_MouseLeftButtonDown" 
                                    MouseMove="PolygonCanvas_MouseMove" 
                                    MouseRightButtonDown="PolygonCanvas_MouseRightButtonDown" />
                            <Canvas x:Name="SamCanvas" Background="Transparent" Visibility="Collapsed" 
                                    MouseLeftButtonDown="SamCanvas_MouseLeftButtonDown" />
                        </Grid>
                        
                        <!-- Invisible slider that captures mouse logic but has a visible thumb line -->
                        <!-- Constraining vertical alignment so it doesn't block the entire canvas height from mouse events -->
                        <Slider x:Name="CompareSlider" Minimum="0" Maximum="1" Value="0.5" Visibility="Collapsed" 
                                VerticalAlignment="Center" Height="50" HorizontalAlignment="Stretch" 
                                ValueChanged="CompareSlider_ValueChanged"
                                Opacity="0.7"/>
                    </Grid>
                </ScrollViewer>
                
                <!-- Drop Zone Overlay -->
                <StackPanel x:Name="DropZone" Background="Transparent" AllowDrop="True" Drop="DropZone_Drop" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="Drag and Drop Image Here" Foreground="#555" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Grid Grid.Row="3">
            <TextBlock x:Name="StatusText" Text="SYSTEM READY..." Foreground="{StaticResource CyberAccentBrush}" HorizontalAlignment="Left" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="LOAD IMAGE" Width="100" Height="30" Margin="0,0,10,0" Click="SelectImage_Click" BorderBrush="{StaticResource CyberMagentaBrush}" Foreground="{StaticResource CyberMagentaBrush}" BorderThickness="1" Background="Transparent" />
                <TextBlock Text="CTRL + MOUSE WHEEL = ZOOM" Foreground="{StaticResource CyberSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
