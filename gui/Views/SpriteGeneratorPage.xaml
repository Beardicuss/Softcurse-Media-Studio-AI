<UserControl x:Class="GeminiWatermarkRemover.Views.SpriteGeneratorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,14,16,16">

                    <TextBlock Text="SPRITE GENERATOR" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource CyberAccentBrush}"
                               FontFamily="Segoe UI" Margin="0,0,0,4">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="AI-powered  |  local  |  no token limits"
                               FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="Segoe UI" Margin="0,0,0,14"/>
                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,14"/>

                    <!-- SOURCE TABS -->
                    <TextBlock Text="SOURCE" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton x:Name="TabGenerate" Grid.Column="0" Content="GENERATE"
                                      IsChecked="True" Height="28" Style="{StaticResource ToggleOutline}"
                                      Padding="0" FontSize="10" Checked="TabGenerate_Checked"/>
                        <ToggleButton x:Name="TabImport" Grid.Column="1" Content="IMPORT IMAGE"
                                      IsChecked="False" Height="28" Style="{StaticResource ToggleOutline}"
                                      Padding="0" FontSize="10" Checked="TabImport_Checked"/>
                    </Grid>

                    <!-- GENERATE PANEL -->
                    <StackPanel x:Name="GeneratePanel">
                        <TextBlock Text="PROMPT" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <TextBox x:Name="PromptBox" Height="64" TextWrapping="Wrap" AcceptsReturn="True"
                                 Style="{StaticResource HudTextBox}" Margin="0,0,0,8"
                                 Text="game character sprite, idle pose, full body, white background, pixel art style, clean edges"/>
                        <TextBlock Text="NEGATIVE PROMPT" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <TextBox x:Name="NegPromptBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True"
                                 Style="{StaticResource HudTextBox}" Margin="0,0,0,8"
                                 Text="blurry, low quality, watermark, signature, extra limbs"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="FRAMES" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <ComboBox x:Name="FrameCountCombo" Style="{StaticResource HudComboBox}" Height="28">
                                    <ComboBoxItem Content="1 (Still)"/>
                                    <ComboBoxItem Content="2 (Blink)"/>
                                    <ComboBoxItem Content="4 (Walk)" IsSelected="True"/>
                                    <ComboBoxItem Content="6 (Run)"/>
                                    <ComboBoxItem Content="8 (Full Cycle)"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="SIZE" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <ComboBox x:Name="SizeCombo" Style="{StaticResource HudComboBox}" Height="28">
                                    <ComboBoxItem Content="256x256"/>
                                    <ComboBoxItem Content="512x512" IsSelected="True"/>
                                    <ComboBoxItem Content="768x768"/>
                                    <ComboBoxItem Content="1024x1024"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="ANIMATION STYLE" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <ComboBox x:Name="AnimStyleCombo" Style="{StaticResource HudComboBox}"
                                  Height="28" Margin="0,0,0,8">
                            <ComboBoxItem Content="Idle Breathe" IsSelected="True"/>
                            <ComboBoxItem Content="Walk Cycle"/>
                            <ComboBoxItem Content="Run Cycle"/>
                            <ComboBoxItem Content="Attack Slash"/>
                            <ComboBoxItem Content="Jump Arc"/>
                            <ComboBoxItem Content="Death Fall"/>
                            <ComboBoxItem Content="Spell Cast"/>
                        </ComboBox>

                        <TextBlock Text="FRAME VARIATION" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="38"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="DenoiseSlider" Grid.Column="0" Minimum="0.1" Maximum="0.9"
                                    Value="0.35" VerticalAlignment="Center"
                                    Foreground="{StaticResource CyberAccentBrush}"
                                    ValueChanged="DenoiseSlider_ValueChanged"/>
                            <TextBlock x:Name="DenoiseLabel" Grid.Column="1" Text="0.35"
                                       Foreground="{StaticResource TextBrush}" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- IMPORT PANEL -->
                    <StackPanel x:Name="ImportPanel" Visibility="Collapsed">
                        <Border Height="90" BorderBrush="{StaticResource BorderBrightBrush}"
                                BorderThickness="1" Background="#06101A" Margin="0,0,0,8">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="+" FontSize="28" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BorderBrightBrush}"/>
                                <TextBlock x:Name="ImportFileLabel" Text="No file selected"
                                           FontSize="10" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                        <Button Content="BROWSE IMAGE" Height="28" Style="{StaticResource BtnOutline}"
                                Margin="0,0,0,8" Click="BrowseImport_Click"/>
                        <TextBlock Text="Import a reference image to generate animation variants from it."
                                   FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,10,0,14"/>

                    <!-- POST-PROCESSING -->
                    <TextBlock Text="POST-PROCESSING" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Remove Background" FontSize="11"
                                       Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI"/>
                            <TextBlock Text="GrabCut-based removal" FontSize="9"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <CheckBox x:Name="RemoveBgCheck" Grid.Column="1" IsChecked="True"
                                  VerticalAlignment="Center" Foreground="{StaticResource CyberAccentBrush}"/>
                    </Grid>

                    <TextBlock Text="OUTLINE STYLE" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="Segoe UI" Margin="0,0,0,4"/>
                    <ComboBox x:Name="OutlineCombo" Style="{StaticResource HudComboBox}"
                              Height="28" Margin="0,0,0,8" SelectionChanged="OutlineCombo_Changed">
                        <ComboBoxItem Content="None" IsSelected="True"/>
                        <ComboBoxItem Content="Solid Outline"/>
                        <ComboBoxItem Content="Neon Glow"/>
                        <ComboBoxItem Content="Double Line"/>
                    </ComboBox>

                    <StackPanel x:Name="OutlineColorPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="OUTLINE COLOR" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="ColorSwatch" Width="28" Height="28" Margin="0,0,6,0"
                                    Background="#00E5FF"
                                    BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"/>
                            <TextBox x:Name="OutlineColorBox" Text="#00E5FF" Width="90" Height="28"
                                     Style="{StaticResource HudTextBox}"
                                     TextChanged="OutlineColor_Changed"/>
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,4,0,14"/>

                    <!-- SPRITE SHEET OPTIONS -->
                    <TextBlock Text="SPRITE SHEET" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="COLUMNS" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ColsCombo" Style="{StaticResource HudComboBox}" Height="28">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="4" IsSelected="True"/>
                                <ComboBoxItem Content="8"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CELL SIZE" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CellSizeCombo" Style="{StaticResource HudComboBox}" Height="28">
                                <ComboBoxItem Content="64 px"/>
                                <ComboBoxItem Content="128 px" IsSelected="True"/>
                                <ComboBoxItem Content="256 px"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,6,0,14"/>

                    <!-- GENERATE + EXPORT -->
                    <Button x:Name="GenerateBtn" Content="GENERATE SPRITES" Height="38"
                            Style="{StaticResource BtnPrimary}" Margin="0,0,0,8"
                            Click="GenerateBtn_Click"/>
                    <Button x:Name="CancelBtn" Content="CANCEL" Height="30"
                            Style="{StaticResource BtnDanger}" Margin="0,0,0,8"
                            Visibility="Collapsed" Click="CancelBtn_Click"/>

                    <ProgressBar x:Name="ProgressBar" Height="4" Margin="0,0,0,6"
                                 Foreground="{StaticResource CyberAccentBrush}"
                                 Background="#0A1520" BorderThickness="0"
                                 Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock x:Name="StatusLabel" Text="READY"
                               FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="Consolas" HorizontalAlignment="Center"/>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,10,0,10"/>

                    <!-- SD WebUI Requirement -->
                    <TextBlock Text="REQUIRES: Stable Diffusion WebUI running with --api flag"
                               FontSize="9" Foreground="#FF6B6B" FontFamily="Segoe UI"
                               TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <Button Content="DOWNLOAD SD WEBUI" Height="28"
                            Style="{StaticResource BtnOutline}" Margin="0,0,0,6"
                            Click="DownloadSdWebui_Click"/>

                    <TextBlock Text="EXPORT" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                    <Button x:Name="ExportSheetBtn" Content="SAVE SPRITE SHEET (PNG)" Height="30"
                            Style="{StaticResource BtnOutline}" Margin="0,0,0,6"
                            IsEnabled="False" Click="ExportSheet_Click"/>
                    <Button x:Name="ExportFramesBtn" Content="SAVE INDIVIDUAL FRAMES" Height="30"
                            Style="{StaticResource BtnOutline}" Margin="0,0,0,6"
                            IsEnabled="False" Click="ExportFrames_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- RIGHT PANEL — Preview -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BG2}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="PreviewFrames" Content="FRAMES" IsChecked="True"
                                  Height="26" Padding="14,0" Style="{StaticResource ToggleOutline}"
                                  Margin="0,0,6,0" Checked="PreviewFrames_Checked"/>
                    <ToggleButton x:Name="PreviewSheet" Content="SPRITE SHEET" IsChecked="False"
                                  Height="26" Padding="14,0" Style="{StaticResource ToggleOutline}"
                                  Margin="0,0,6,0" Checked="PreviewSheet_Checked"/>
                    <ToggleButton x:Name="PreviewAnim" Content="ANIMATE" IsChecked="False"
                                  Height="26" Padding="14,0" Style="{StaticResource ToggleOutline}"
                                  Checked="PreviewAnim_Checked" Unchecked="PreviewAnim_Unchecked"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#050C13" Margin="12" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#00E5FF" BlurRadius="18" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsHitTestVisible="False">
                        <TextBlock Text="No sprites yet" FontSize="16" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI"/>
                        <TextBlock Text="Configure and press GENERATE SPRITES" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"
                                   Foreground="{StaticResource BorderBrightBrush}" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <ScrollViewer x:Name="FramesScrollView" Visibility="Collapsed"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="FrameWrap" Margin="16" HorizontalAlignment="Center"/>
                    </ScrollViewer>

                    <ScrollViewer x:Name="SheetScrollView" Visibility="Collapsed"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Image x:Name="SheetPreviewImage" Stretch="Uniform" Margin="16"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </ScrollViewer>

                    <Grid x:Name="AnimView" Visibility="Collapsed">
                        <Rectangle>
                            <Rectangle.Fill>
                                <DrawingBrush Viewport="0,0,16,16" ViewportUnits="Absolute" TileMode="Tile">
                                    <DrawingBrush.Drawing>
                                        <DrawingGroup>
                                            <GeometryDrawing Brush="#1A2030">
                                                <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,16,16"/></GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                            <GeometryDrawing Brush="#111820">
                                                <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,8,8"/></GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                            <GeometryDrawing Brush="#111820">
                                                <GeometryDrawing.Geometry><RectangleGeometry Rect="8,8,8,8"/></GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingGroup>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Image x:Name="AnimPreviewImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               MaxWidth="512" MaxHeight="512"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Orientation="Horizontal" Margin="0,0,16,12">
                            <TextBlock Text="FPS:" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" FontFamily="Segoe UI"/>
                            <Slider x:Name="FpsSlider" Minimum="1" Maximum="24" Value="8" Width="90"
                                    VerticalAlignment="Center" Foreground="{StaticResource CyberAccentBrush}"
                                    ValueChanged="FpsSlider_Changed"/>
                            <TextBlock x:Name="FpsLabel" Text="8" FontSize="10" Width="24"
                                       Foreground="{StaticResource TextBrush}" FontFamily="Consolas"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource BG2}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
                <Grid>
                    <TextBlock x:Name="InfoLabel" Text="No sprites generated yet"
                               FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
