<UserControl x:Class="GeminiWatermarkRemover.Views.BatchProcessorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <Grid>

        
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="ADD FOLDER" Click="AddFolder_Click" Margin="0,0,10,0" BorderBrush="{StaticResource CyberSecondaryBrush}" Foreground="{StaticResource CyberSecondaryBrush}" BorderThickness="1" Background="Transparent" />
            <Button Content="ADD FILES" Click="AddFiles_Click" Margin="0,0,10,0" BorderBrush="{StaticResource CyberSecondaryBrush}" Foreground="{StaticResource CyberSecondaryBrush}" BorderThickness="1" Background="Transparent" />
            <Button Content="CLEAR LIST" Click="ClearList_Click" BorderBrush="{StaticResource CyberMagentaBrush}" Foreground="{StaticResource CyberMagentaBrush}" BorderThickness="1" Background="Transparent" />
        </StackPanel>
        
        <ListView x:Name="FileListView" Grid.Row="1" Margin="0,0,0,10" SelectionMode="Extended" Background="#1100FFFF" BorderBrush="{StaticResource CyberAccentBrush}" BorderThickness="1" Foreground="{StaticResource CyberAccentBrush}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="100"/>
                    <GridViewColumn Header="Filename" DisplayMemberBinding="{Binding FileName}" Width="200"/>
                    <GridViewColumn Header="Path" DisplayMemberBinding="{Binding FilePath}" Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="OUTPUT FOLDER:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource CyberAccentBrush}"/>
            <TextBox x:Name="OutputFolderTextBox" Width="380" Margin="0,0,10,0" BorderBrush="{StaticResource CyberAccentBrush}" Foreground="#00FFFF" Background="#1100FFFF"/>
            <Button Content="BROWSE" Click="BrowseOutputFolder_Click" BorderBrush="{StaticResource CyberSecondaryBrush}" Foreground="{StaticResource CyberSecondaryBrush}" BorderThickness="1" Background="Transparent" />
        </StackPanel>
        
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="BatchProgressBar" Grid.Column="0" Height="20" Margin="0,0,15,0" Minimum="0" Maximum="100" Foreground="{StaticResource CyberMagentaBrush}" Background="#1100FFFF" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="StartBatchButton" Content="START BATCH" Width="180" Height="35" Click="StartBatch_Click" ui:ControlHelper.CornerRadius="0" Background="{StaticResource CyberAccentBrush}" Foreground="#020202" FontWeight="Bold">
                    <Button.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="10" ShadowDepth="0" />
                    </Button.Effect>
                </Button>
                <Button x:Name="CancelBatchButton" Content="CANCEL" Width="90" Height="35" Click="CancelBatch_Click" Margin="10,0,0,0" Visibility="Collapsed" BorderBrush="{StaticResource CyberMagentaBrush}" Foreground="{StaticResource CyberMagentaBrush}" BorderThickness="1" Background="Transparent"/>
            </StackPanel>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
