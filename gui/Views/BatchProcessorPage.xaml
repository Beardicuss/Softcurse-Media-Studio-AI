<UserControl x:Class="GeminiWatermarkRemover.Views.BatchProcessorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             Background="Transparent">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title + buttons -->
            <RowDefinition Height="*"/>      <!-- File list -->
            <RowDefinition Height="Auto"/>   <!-- Output folder -->
            <RowDefinition Height="Auto"/>   <!-- Progress + actions -->
        </Grid.RowDefinitions>

        <!-- ── TOP: Title + Add/Clear buttons ── -->
        <Border Grid.Row="0" Margin="0,0,0,12"
                BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="0,0,0,1"
                Padding="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="BATCH PROCESSOR" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource CyberAccentBrush}" VerticalAlignment="Center"
                           FontFamily="Segoe UI">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="ADD FOLDER" Click="AddFolder_Click" Margin="0,0,8,0"
                            Style="{StaticResource BtnOutline}" Padding="12,6"/>
                    <Button Content="ADD FILES" Click="AddFiles_Click" Margin="0,0,8,0"
                            Style="{StaticResource BtnOutline}" Padding="12,6"/>
                    <Button Content="CLEAR LIST" Click="ClearList_Click"
                            Style="{StaticResource BtnDanger}" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── FILE LIST ── -->
        <Border Grid.Row="1" Margin="0,0,0,12"
                BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                Background="#071018">
            <ListView x:Name="FileListView" SelectionMode="Extended"
                      Background="Transparent" BorderThickness="0"
                      Foreground="{StaticResource TextBrush}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="100"/>
                        <GridViewColumn Header="Filename" DisplayMemberBinding="{Binding FileName}" Width="200"/>
                        <GridViewColumn Header="Path" DisplayMemberBinding="{Binding FilePath}" Width="400"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- ── OUTPUT FOLDER ── -->
        <Border Grid.Row="2" Margin="0,0,0,12"
                BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                Background="#071018" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="OUTPUT FOLDER:" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10"
                           FontWeight="Bold" FontFamily="Segoe UI"/>
                <TextBox x:Name="OutputFolderTextBox" Width="400" Margin="0,0,10,0"
                         Style="{StaticResource HudTextBox}"/>
                <Button Content="BROWSE" Click="BrowseOutputFolder_Click"
                        Style="{StaticResource BtnOutline}" Padding="12,6"/>
            </StackPanel>
        </Border>

        <!-- ── PROGRESS + START/CANCEL ── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrightBrush}"
                    BorderThickness="1" Background="#071018" Margin="0,0,15,0" Padding="4">
                <ProgressBar x:Name="BatchProgressBar" Height="18" Minimum="0"
                             Foreground="{StaticResource CyberAccentBrush}"
                             Background="Transparent"/>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="StartBatchButton" Content="START BATCH" Width="180" Height="35"
                        Click="StartBatch_Click" Style="{StaticResource BtnPrimary}"
                        Padding="14,0"/>
                <Button x:Name="CancelBatchButton" Content="CANCEL" Height="35"
                        Click="CancelBatch_Click" Margin="10,0,0,0" Visibility="Collapsed"
                        Style="{StaticResource BtnDanger}" Padding="14,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
