<UserControl x:Class="GeminiWatermarkRemover.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             Background="Transparent">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="SYSTEM SETTINGS" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource CyberAccentBrush}"
                       FontFamily="Segoe UI">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- General Settings -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                Background="#0A1520" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="GENERAL" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource CyberAccentBrush}" Margin="0,0,0,12"
                           FontFamily="Segoe UI"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Default Output Folder:" VerticalAlignment="Center" Width="180"
                               Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI" FontSize="11"/>
                    <TextBox x:Name="DefaultOutputTextBox" Width="320" Style="{StaticResource HudTextBox}"/>
                    <Button Content="BROWSE" Height="30" Margin="10,0,0,0"
                            Style="{StaticResource BtnOutline}" Padding="12,0"
                            Click="BrowseOutput_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- AI Model Execution -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                Background="#0A1520" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="AI MODEL EXECUTION" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource CyberAccentBrush}" Margin="0,0,0,12"
                           FontFamily="Segoe UI"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Execution Provider:" VerticalAlignment="Center" Width="180"
                               Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI" FontSize="11"/>
                    <ComboBox x:Name="ExecutionProviderCombo" Width="220" Style="{StaticResource HudComboBox}">
                        <ComboBoxItem Content="CPU (Default)"/>
                        <ComboBoxItem Content="CUDA (NVIDIA GPU)"/>
                        <ComboBoxItem Content="DirectML (Any GPU)"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock Text="Note: GPU execution requires appropriate CUDA/DirectML drivers installed."
                           FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="180,0,0,0"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- Generative Fill API -->
        <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                Background="#0A1520" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="GENERATIVE FILL API" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource CyberAccentBrush}" Margin="0,0,0,12"
                           FontFamily="Segoe UI"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="SD WebUI API Endpoint:" VerticalAlignment="Center" Width="180"
                               Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI" FontSize="11"/>
                    <TextBox x:Name="ApiEndpointTextBox" Text="http://127.0.0.1:7860/"
                             Width="320" Style="{StaticResource HudTextBox}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Save -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="SAVE SETTINGS" Height="36" Padding="24,0"
                    Style="{StaticResource BtnPrimary}"
                    Click="SaveSettings_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
