<UserControl x:Class="GeminiWatermarkRemover.Views.GenerativeFillPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <Grid>

        
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="STABLE DIFFUSION IMG2IMG NEURAL LINK" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="{StaticResource CyberAccentBrush}">
            <TextBlock.Effect>
                <DropShadowEffect Color="#00FFFF" BlurRadius="10" ShadowDepth="0" />
            </TextBlock.Effect>
        </TextBlock>

        <StackPanel Grid.Row="1">
            <TextBlock Text="PROMPT:" Margin="0,0,0,5" Foreground="{StaticResource CyberSecondaryBrush}"/>
            <TextBox x:Name="PromptTextBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" Text="A beautiful landscape, high quality, 8k resolution" BorderBrush="{StaticResource CyberAccentBrush}" Foreground="#00FFFF" Background="#1100FFFF"/>

            <TextBlock Text="NEGATIVE PROMPT:" Margin="0,0,0,5" Foreground="{StaticResource CyberMagentaBrush}"/>
            <TextBox x:Name="NegativePromptTextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" Text="watermark, text, signature, low quality" BorderBrush="{StaticResource CyberMagentaBrush}" Foreground="#FF00FF" Background="#11FF00FF"/>

            <TextBlock Text="API ENDPOINT (SD WEBUI):" Margin="0,0,0,5" Foreground="{StaticResource CyberSecondaryBrush}"/>
            <TextBox x:Name="ApiEndpointTextBox" Text="http://127.0.0.1:7860/sdapi/v1/img2img" Margin="0,0,0,10" BorderBrush="{StaticResource CyberSecondaryBrush}" Foreground="#0088FF" Background="#110088FF"/>
            
            <TextBlock TextWrapping="Wrap" Foreground="#0088FF" FontSize="12" Opacity="0.8">
                THIS PROTOCOL REQUIRES A LOCAL INSTANCE OF STABLE DIFFUSION WEBUI RUNNING WITH THE --API FLAG. 
                IT SENDS THE IMAGE AND MASK TO THE SD API FOR ADVANCED GENERATIVE INPAINTING.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ABORT" Click="Cancel_Click" Margin="0,0,10,0" BorderBrush="{StaticResource CyberMagentaBrush}" Foreground="{StaticResource CyberMagentaBrush}" BorderThickness="1" Background="Transparent" />
            <Button x:Name="GenerateButton" Content="INITIALIZE GENERATION" Click="Generate_Click" ui:ControlHelper.CornerRadius="0" Background="{StaticResource CyberAccentBrush}" Foreground="#020202" FontWeight="Bold">
                <Button.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="10" ShadowDepth="0" />
                </Button.Effect>
            </Button>
        </StackPanel>
        </Grid>
    </Grid>
</UserControl>
