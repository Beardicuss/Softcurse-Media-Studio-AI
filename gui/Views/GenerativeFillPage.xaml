<UserControl x:Class="SoftcurseMediaLabAI.Views.GenerativeFillPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             Background="Transparent">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title -->
            <RowDefinition Height="*"/>      <!-- Form fields -->
            <RowDefinition Height="Auto"/>   <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- ── TITLE ── -->
        <TextBlock Grid.Row="0" Text="STABLE DIFFUSION IMG2IMG NEURAL LINK"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,14"
                   Foreground="{StaticResource CyberAccentBrush}" FontFamily="Segoe UI">
            <TextBlock.Effect>
                <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- ── FORM FIELDS ── -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrightBrush}"
                BorderThickness="1" Background="#071018" Padding="16,14">
            <StackPanel>
                <TextBlock Text="PROMPT" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="PromptTextBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="0,0,0,14" Style="{StaticResource HudTextBox}"
                         Text="A beautiful landscape, high quality, 8k resolution"/>

                <TextBlock Text="NEGATIVE PROMPT" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource GoldAccentBrush}" FontFamily="Segoe UI"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="NegativePromptTextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="0,0,0,14" Style="{StaticResource HudTextBox}"
                         Text="watermark, text, signature, low quality"/>

                <TextBlock Text="API ENDPOINT (SD WEBUI)" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextDimBrush}" FontFamily="Segoe UI"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="ApiEndpointTextBox" Margin="0,0,0,14" Style="{StaticResource HudTextBox}"
                         Text="http://127.0.0.1:7860/sdapi/v1/img2img"/>

                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextDimBrush}" FontSize="11"
                           FontFamily="Consolas" Opacity="0.7">
                    THIS PROTOCOL REQUIRES A LOCAL INSTANCE OF STABLE DIFFUSION WEBUI RUNNING WITH THE --API FLAG. 
                    IT SENDS THE IMAGE AND MASK TO THE SD API FOR ADVANCED GENERATIVE INPAINTING.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── ACTIONS ── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="ABORT" Click="Cancel_Click" Margin="0,0,10,0"
                    Style="{StaticResource BtnDanger}" Padding="14,6"/>
            <Button x:Name="GenerateButton" Content="INITIALIZE GENERATION" Click="Generate_Click"
                    Style="{StaticResource BtnPrimary}" Padding="14,6"/>
        </StackPanel>
    </Grid>
</UserControl>
